---
import Layout from "@layouts/Layout.astro";
---

<Layout>
  <div class="container">
    <h1>josepro@dev:~$ whoami</h1>

    <div class="content">
      <p>
        Desarrollador full-stack apasionado por crear soluciones web modernas.
        Trabajo con JavaScript, React y Node.js.
      </p>

      <div class="section">
        <h2>skills</h2>
        <p>JavaScript • React • Node.js • TypeScript • CSS • Git • SQL</p>
      </div>

      <div class="section">
        <h2>contact</h2>
        <p>
          <a href="https://github.com" target="_blank">github</a> •
          <a href="https://twitter.com" target="_blank">twitter</a> •
          <a href="mailto:jose@example.com">email</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<style>
  .container {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    color: var(--orange);
  }

  h2 {
    font-size: 0.95rem;
    margin: 1.5rem 0 0.5rem 0;
    color: var(--orange);
  }

  .content {
    line-height: 1.8;
  }

  .content p {
    margin: 0 0 1rem 0;
    color: var(--text-grey);
  }

  .section p {
    color: var(--text-white);
  }

  a {
    color: var(--orange);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  a:hover {
    opacity: 0.8;
  }
</style>
